{
	"name": "@moonforge/generator",
	"version": "0.1.0",
	"description": "MoonForge project generator - template merging and zip creation",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./template-loader": {
			"import": "./dist/template-loader.js",
			"types": "./dist/template-loader.d.ts"
		},
		"./template-loader.js": {
			"import": "./dist/template-loader.js",
			"types": "./dist/template-loader.d.ts"
		},
		"./src/*": {
			"import": "./src/*.ts",
			"types": "./src/*.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "npx tsc --watch",
		"typecheck": "npx tsc --noEmit"
	},
	"dependencies": {
		"adm-zip": "^0.5.16"
	},
	"devDependencies": {
		"@types/adm-zip": "^0.5.7",
		"@types/node": "^20.11.17",
		"typescript": "^5.8.3"
	},
	"peerDependencies": {
		"zod": "^3.0.0"
	}
}
