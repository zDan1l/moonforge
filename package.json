{
	"name": "app",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"api:dev": "pnpm run --filter=api dev",
		"web:dev": "pnpm run --filter=web dev",
		"generator:dev": "pnpm run --filter=@moonforge/generator dev",
		"dev": "concurrently \"pnpm:generator:dev\" \"pnpm:api:dev\" \"pnpm:web:dev\" --names \"GEN,API,WEB\" --prefix-colors \"blue,green,cyan\"",
