// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(255)
  description String        @db.Text
  status      ProjectStatus @default(PENDING)
  openspec    Json?         // Store the OpenSpec JSON
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  files       ProjectFile[]

  @@index([status])
  @@index([createdAt])
}

model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  path      String   @db.VarChar(500)
  content   String   @db.Text
  mimeType  String   @db.VarChar(100)
  size      Int      @default(0)
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
  @@map("project_files")
}

enum ProjectStatus {
  PENDING     // Initial state, project created
  PREVIEWING  // OpenSpec generated, waiting for user confirmation
  GENERATING  // Generation in progress
  GENERATED   // All files generated successfully
  MODIFIED    // Project has been modified after generation
  FAILED      // Generation failed
}
